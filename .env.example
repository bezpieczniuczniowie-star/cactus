# Environment Configuration for CACTUS Mailer

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
WEB_URL=http://localhost:3001
API_PREFIX=/api/v1
APP_NAME=CACTUS Mailer
APP_VERSION=1.0.0

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://cactus:cactus_password@localhost:5432/cactus_db
DATABASE_POOL_SIZE=20
DATABASE_IDLE_TIMEOUT=30000
DATABASE_CONNECTION_TIMEOUT=10000

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_PORT=6379

# ============================================
# SMTP Configuration (Default)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@cactusmailer.com
SMTP_FROM_NAME=CACTUS Mailer
SMTP_REPLY_TO=support@cactusmailer.com

# ============================================
# SendGrid Configuration (Optional)
# ============================================
SENDGRID_ENABLED=false
SENDGRID_API_KEY=

# ============================================
# AWS SES Configuration (Optional)
# ============================================
AWS_SES_ENABLED=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ============================================
# Mailgun Configuration (Optional)
# ============================================
MAILGUN_ENABLED=false
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ============================================
# Authentication & Security
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d
API_KEY_SECRET=your-api-key-encryption-secret-change-in-production
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production
API_KEY_PREFIX=CTS

# ============================================
# Session Configuration
# ============================================
SESSION_SECRET=your-session-secret-change-in-production
SESSION_TIMEOUT=1800000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_HTTP_ONLY=true

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_KEY_GENERATOR=ip

# ============================================
# Email Queue Configuration
# ============================================
MAX_RETRY_ATTEMPTS=5
RETRY_BACKOFF_MULTIPLIER=2
RETRY_BACKOFF_DELAY=5000
QUEUE_TIMEOUT=30000
BATCH_SIZE=100
BATCH_DELAY=1000
WORKER_CONCURRENCY=10
WORKER_MAX_ATTEMPTS=3
WORKER_TIMEOUT=60000

# ============================================
# Tracking Configuration
# ============================================
TRACKING_ENABLED=true
TRACKING_DOMAIN=track.localhost:3000
TRACKING_PIXEL_ENABLED=true
CLICK_TRACKING_ENABLED=true
OPEN_TRACKING_ENABLED=true
TRACKING_SECRET=your-tracking-secret-key
TRACKING_EXPIRE_DAYS=90

# ============================================
# Webhook Configuration
# ============================================
WEBHOOK_ENABLED=true
WEBHOOK_TIMEOUT=30000
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=5000
WEBHOOK_SIGNATURE_ALGORITHM=sha256

# ============================================
# Email Validation
# ============================================
EMAIL_VALIDATION_ENABLED=true
EMAIL_VALIDATION_STRICT=false

# ============================================
# Suppression Lists
# ============================================
SUPPRESSION_CHECK_ENABLED=true
BOUNCE_SUPPRESSION_ENABLED=true
COMPLAINT_SUPPRESSION_ENABLED=true
UNSUBSCRIBE_SUPPRESSION_ENABLED=true

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=30
LOG_CONSOLE=true

# ============================================
# Error Tracking (Sentry)
# ============================================
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACE_SAMPLE_RATE=0.1

# ============================================
# Monitoring (Datadog)
# ============================================
DATADOG_ENABLED=false
DATADOG_API_KEY=
DATADOG_SITE=datadoghq.com

# ============================================
# Prometheus Metrics
# ============================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGINS=http://localhost:3001,http://localhost:3000,http://localhost:3002
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-API-Key,X-Request-ID
CORS_EXPOSE_HEADERS=X-Total-Count,X-Page-Count
CORS_MAX_AGE=86400

# ============================================
# File Upload Configuration
# ============================================
MAX_FILE_SIZE=5242880
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
UPLOAD_DIR=./uploads

# ============================================
# Data Retention & Cleanup
# ============================================
RETENTION_DAYS=90
ARCHIVE_ENABLED=true
ARCHIVE_DIR=./archive
CLEANUP_CRON=0 2 * * *

# ============================================
# Feature Flags
# ============================================
FEATURE_A_B_TESTING=true
FEATURE_TEMPLATES=true
FEATURE_WEBHOOKS=true
FEATURE_ANALYTICS=true
FEATURE_CUSTOM_DOMAINS=true
FEATURE_IP_POOLING=false
FEATURE_ADVANCED_SEGMENTATION=false
FEATURE_SMS_SENDING=false
FEATURE_PUSH_NOTIFICATIONS=false

# ============================================
# Third-party Integrations
# ============================================
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=
PAGERDUTY_ENABLED=false
PAGERDUTY_INTEGRATION_KEY=

# ============================================
# External Services
# ============================================
RECAP_ENABLED=false
RECAP_SITE_KEY=
RECAP_SECRET_KEY=
STRIPE_ENABLED=false
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# ============================================
# Development & Debug
# ============================================
DEBUG=cactus:*
DEVELOPMENT_MODE=true
MOCK_EMAIL_SENDING=false
DRY_RUN=false
